#!/usr/bin/env bash
set -eu

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
status=0

ok() { printf '[ok] %s\n' "$1"; }
warn() { printf '[warn] %s\n' "$1"; }
fail() { printf '[fail] %s\n' "$1"; status=1; }

is_git_repo() {
  git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

check_tracked_env() {
  if ! is_git_repo; then
    warn "not a git repo; skipping tracked .env check"
    return
  fi

  tracked_env="$(
    git -C "$ROOT" ls-files |
      grep -E '(^|/)\.env(\..*)?$' |
      grep -Ev '(^|/)\.env\.(example|sample|template)$' || true
  )"

  if [ -n "$tracked_env" ]; then
    fail "tracked env file found"
    printf '%s\n' "$tracked_env"
  else
    ok "no tracked .env files"
  fi
}

scan_secrets() {
  secret_regex='(api[_-]?key|secret|token|password|passwd|private[_-]?key)[[:space:]]*[:=][[:space:]]*["'\'']?[^"'\''][^[:space:]]{11,}'
  known_regex='AKIA[0-9A-Z]{16}|ghp_[0-9A-Za-z]{36}|github_pat_[0-9A-Za-z_]{40,}|sk-[0-9A-Za-z]{20,}|-----BEGIN [A-Z ]*PRIVATE KEY-----'
  findings=0

  while IFS= read -r file; do
    if grep -I -i -E "$secret_regex|$known_regex" "$file" >/dev/null 2>&1; then
      findings=$((findings + 1))
      grep -n -I -i -E "$secret_regex|$known_regex" "$file" |
        while IFS=: read -r path line _; do
          printf '[secret?] %s:%s\n' "$path" "$line"
        done
    fi
  done < <(
    find "$ROOT" \
      \( -path "$ROOT/.git" \
      -o -path "$ROOT/node_modules" \
      -o -path "$ROOT/dist" \
      -o -path "$ROOT/build" \
      -o -path "$ROOT/.cache" \
      -o -path "$ROOT/.agent-framework-backups" \
      \) -prune -o -type f -print
  )

  if [ "$findings" -gt 0 ]; then
    fail "possible secrets found; paths only shown, inspect and redact"
  else
    ok "no obvious secrets found"
  fi
}

run_framework_check() {
  if [ -f "$ROOT/installers/verify-framework.sh" ]; then
    bash "$ROOT/installers/verify-framework.sh"
    ok "framework verifier passed"
  else
    warn "no framework verifier found"
  fi
}

run_native_checks() {
  if [ -f "$ROOT/package.json" ] && command -v npm >/dev/null 2>&1; then
    npm --prefix "$ROOT" run lint --if-present
    npm --prefix "$ROOT" test --if-present
    if [ -f "$ROOT/package-lock.json" ]; then
      npm --prefix "$ROOT" audit --audit-level=high
    fi
    ok "npm checks completed"
  else
    warn "no package.json; skipping npm lint/test/audit"
  fi
}

printf 'security check: %s\n' "$ROOT"
check_tracked_env
scan_secrets
run_framework_check
run_native_checks

if [ "$status" -ne 0 ]; then
  printf 'security check: failed\n'
  exit "$status"
fi

printf 'security check: ok\n'
